# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit it.

# ── Apple Developer (code signing & notarization) ─────────────────────────────
# Required by build.sh and make_dmg.sh for Developer ID signing.
# Without these the scripts fall back to ad-hoc (self) signing automatically.
SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"
APPLE_ID="you@example.com"
TEAM_ID="ABCDE12345"
APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"   # App-specific password from appleid.apple.com

# ── AWS (website deployment) ──────────────────────────────────────────────────
# Required by scripts/deploy_website.sh, called at the end of publish_github.sh.
# Without these the website deployment step is silently skipped.
#
# IAM permissions needed (attach to the key's user/role):
#   s3:PutObject               on arn:aws:s3:::BUCKET_NAME/*
#   cloudfront:CreateInvalidation
#   cloudfront:GetInvalidation  (for the completion-wait)
#   Both CloudFront actions on arn:aws:cloudfront::ACCOUNT_ID:distribution/DIST_ID
S3_BUCKET_NAME="your-bucket-name"
CLOUDFRONT_DISTRIBUTION_ID="EXXXXXXXXXXXX"
AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
AWS_DEFAULT_REGION="eu-west-1"